# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# pgAdmin
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_API_BASE=http://localhost:11434

# MCP Toolbox
TOOLBOX_URL=http://127.0.0.1:5001

# ADK Agent
AGENT_PORT=8000

# LLM Provider: "ollama" (local) or "gemini"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b

# Gemini API Key (wajib diisi jika LLM_PROVIDER=gemini)
GEMINI_API_KEY=
