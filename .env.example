# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# pgAdmin
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Ollama
OLLAMA_API_BASE=http://localhost:11434

# MCP Toolbox
TOOLBOX_URL=http://127.0.0.1:5001

# ADK Agent
AGENT_PORT=8000

# LLM Provider: "ollama" (local) or "gemini"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b

# Gemini API Key — wajib untuk docker compose (layanan-embedding-seed one-shot).
# Diperlukan juga jika LLM_PROVIDER=gemini, dan untuk tool cari-layanan-semantik / RAG embeddings.
GEMINI_API_KEY=

# Opsional: jika "1" / "true", skip pemanggilan API embedding bila SEMUA baris layanan_konsuler
# sudah punya kolom embedding (menghemat quota saat compose up berulang). GEMINI_API_KEY tetap harus ada di .env.
# SEED_EMBEDDINGS_SKIP_IF_FULL=

# Ngrok (required for external access)
NGROK_AUTHTOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_PORT=8080
WEBHOOK_BASE_URL=

# Human Agent Handoff
# ID grup Telegram internal staf KJRI (format: -100xxxxxxxxxx)
# Dapatkan dengan menambahkan @userinfobot ke grup dan ketik /start
KJRI_STAFF_TELEGRAM_GROUP_ID=-100xxxxxxxxxx
