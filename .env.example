# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# pgAdmin
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Ollama
OLLAMA_API_BASE=http://localhost:11434

# MCP Toolbox
TOOLBOX_URL=http://127.0.0.1:5001

# ADK Agent
AGENT_PORT=8000

# LLM Provider: "ollama" (local) or "gemini"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b

# Gemini API Key (wajib diisi jika LLM_PROVIDER=gemini)
# Juga wajib untuk semantic search (text-embedding-004) meskipun LLM_PROVIDER=ollama
GEMINI_API_KEY=

# Ngrok (required for external access)
NGROK_AUTHTOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_PORT=8080
WEBHOOK_BASE_URL=
