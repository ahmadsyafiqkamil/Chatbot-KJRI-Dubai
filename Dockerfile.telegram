FROM python:3.10-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir httpx fastapi "uvicorn[standard]"

COPY chatbot_kjri_dubai/ ./chatbot_kjri_dubai/

EXPOSE 8080

CMD ["uvicorn", "chatbot_kjri_dubai.telegram_bot:app", "--host", "0.0.0.0", "--port", "8080"]
